# Backend port (must be 3001 to match the Google redirect URI)
PORT=3001

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/realtime-ai

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Secret used to sign the JWT token (any long random string)
JWT_SECRET=your-long-random-secret

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Public SWAPI mirror
SWAPI_BASE_URL=https://www.swapi.tech/api
